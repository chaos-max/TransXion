# AML Terraformer Environment Variables
# Copy this file to .env and configure your settings

# Data directory containing accounts.csv and transactions.csv
AML_DATA_DIR=data

# Path to Multi-GNN project (for GNN-based monitoring)
MULTIGNN_PATH=/path/to/multignn

# Path to Qwen model (for local inference)
QWEN_MODEL_PATH=/path/to/Qwen2.5-7B

# LLM API Keys (choose one based on your provider)
# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
